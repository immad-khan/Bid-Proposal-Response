# ==============================================================================
# RFP Proposal Response Engine Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your actual keys/secrets.
# NEVER commit .env to version control.

# --- General Ports & Hosts ---
PORT_NET_API=5000
PORT_AI_ENGINE=8000
PORT_FRONTEND=3000

# --- LLM Provider API Keys (at least one required) ---
LLM_PROVIDER=groq                          # Options: groq | openai | anthropic
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Azure Blob Storage (RFP PDF Uploads) ---
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
AZURE_BLOB_CONTAINER_NAME=rfp-uploads

# --- Qdrant Cloud (Vector Store) ---
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Neo4j (Compliance Graph Database) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --- Redis (Caching & Session State) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Elasticsearch (Keyword / BM25 Fallback) ---
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# --- JWT Authentication (.NET Backend) ---
JWT_KEY=SUPER_SECRET_SECURITY_KEY_FOR_JWT_AUTHENTICATION_32_BYTES_LONG
JWT_ISSUER=BidProposalResponseIssuer
JWT_AUDIENCE=BidProposalResponseAudience

# --- Go/No-Go ML Model Path ---
GONOGO_MODEL_PATH=models/go_nogo_classifier.pkl

# --- Frontend App Config ---
NEXT_PUBLIC_API_URL=http://localhost:5000
