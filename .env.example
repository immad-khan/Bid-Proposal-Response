# ==============================================================================
# RFP Proposal Response Engine Configuration Template
# ==============================================================================

# --- General Ports & Hosts ---
PORT_NET_API=5000
PORT_AI_ENGINE=8000
PORT_FRONTEND=3000

# --- LLM Provider API Keys ---
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Azure Storage / Blob Storage (RFP PDF Uploads) ---
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string_here
AZURE_BLOB_CONTAINER_NAME=rfp-documents

# --- Qdrant (Vector Store) ---
QDRANT_URL=https://94c5ebf0-8087-421a-a94c-f8f0a86585d0.us-east-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# --- Neo4j (Compliance Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --- Redis (Caching & Job Queues) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Elasticsearch (Keyword / BM25 Search) ---
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# --- Frontend App Config ---
NEXT_PUBLIC_API_URL=http://localhost:5000
